datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String        @id @default(uuid())
  email           String        @unique
  passwordHash    String        @map("password_hash")
  name            String?       // Tên hiển thị của người dùng
  balance         Decimal       @default(10000000.00) @db.Decimal(12, 2)
  walletBalance   Decimal       @default(0) @db.Decimal(12, 2) @map("wallet_balance")
  frozenBalance   Decimal       @default(0) @db.Decimal(12, 2) @map("frozen_balance")
  reputationScore Float         @default(5.0) @map("reputation_score")
  createdAt       DateTime      @default(now()) @map("created_at")
  isVerifiedSeller Boolean      @default(false) @map("is_verified_seller")
  idCardNumber     String?      @map("id_card_number")
  idCardImageUrl   String?      @map("id_card_image_url")
  shopAddress      String?      @map("shop_address")
  kycStatus        KycStatus    @default(NONE) @map("kyc_status")
  avatarUrl        String?      @map("avatar_url")
  phoneNumber      String?      @map("phone_number")
  // Ban system
  isBanned         Boolean      @default(false) @map("is_banned")
  banReason        String?      @map("ban_reason")
  bannedAt         DateTime?    @map("banned_at")
  // Admin role — chỉ được gán thủ công hoặc qua seed script
  isAdmin          Boolean      @default(false) @map("is_admin")
  kycRejectionReason String?      @map("kyc_rejection_reason")

  bids            Bid[]
  transactions    Transaction[]
  disputeTickets  DisputeTicket[]  @relation("UserDisputeTickets")
  disputeMessages DisputeMessage[] @relation("UserDisputeMessages")
  soldProducts    Product[]     @relation("ProductSeller")
  wonProducts     Product[]     @relation("ProductWinner")
  watchlist       Watchlist[]   @relation("UserWatchlist")
  reviewsGiven    Review[]      @relation("ReviewsGiven")
  reviewsReceived Review[]      @relation("ReviewsReceived")
  notifications   Notification[] @relation("UserNotifications")
  auditLogs       AuditLog[]
  supportTickets  SupportTicket[]
  supportMessages SupportMessage[]
  orderMessages   OrderMessage[] @relation("UserOrderMessages")
  walletRequests  WalletRequest[] @relation("UserWalletRequests")
  resolvedRequests WalletRequest[] @relation("AdminResolvedRequests")

  @@map("users")
}

model Product {
  id            String             @id @default(uuid())
  title         String
  description   String?
  imageUrl      String?            @map("image_url")
  startPrice    Decimal            @map("start_price") @db.Decimal(12, 2)
  currentPrice  Decimal            @map("current_price") @db.Decimal(12, 2)
  buyNowPrice   Decimal?           @map("buy_now_price") @db.Decimal(12, 2)
  reservePrice  Decimal?           @map("reserve_price") @db.Decimal(12, 2)
  stepPrice     Decimal            @default(10000) @map("step_price") @db.Decimal(12, 2)
  autoExtension Boolean            @default(true) @map("auto_extension")
  startTime     DateTime           @default(now()) @map("start_time")
  endTime       DateTime           @map("end_time")
  status        ProductStatus      @default(DRAFT)
  // Approval system
  approvalStatus ProductApprovalStatus @default(PENDING_REVIEW) @map("approval_status")
  rejectionReason String?          @map("rejection_reason")
  rejectedAt    DateTime?          @map("rejected_at")
  editCount     Int                @default(0) @map("edit_count")
  // Soft delete for ended auctions
  deletedAt     DateTime?          @map("deleted_at")

  categoryId    String             @map("category_id")
  weight        Float              @default(0.5)
  length        Int                @default(10)
  width         Int                @default(10)
  height        Int                @default(10)
  provinceId    String             @default("") @map("province_id")
  districtId    String             @default("") @map("district_id")
  
  sellerId      String             @map("seller_id")
  seller        User               @relation("ProductSeller", fields: [sellerId], references: [id])
  winnerId      String?            @map("winner_id")
  winner        User?              @relation("ProductWinner", fields: [winnerId], references: [id])
  winnerName    String?            @map("winner_name")
  winnerPhone   String?            @map("winner_phone")
  winnerAddress String?            @map("winner_address")
  shippingFee   Decimal?           @map("shipping_fee") @db.Decimal(12, 2)
  category      Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  bids          Bid[]
  attributes    ProductAttribute[]
  disputeTicket DisputeTicket?
  review        Review?
  watchlist     Watchlist[]        @relation("ProductWatchlist")
  transactions  Transaction[]
  orderMessages OrderMessage[]     @relation("ProductOrderMessages")

  @@index([status])
  @@index([approvalStatus])
  @@index([categoryId])
  @@index([sellerId])
  @@index([winnerId])
  @@index([endTime])
  @@index([deletedAt])
  @@map("products")
}

model Category {
  id            String         @id @default(uuid())
  name          String
  slug          String         @unique
  products      Product[]
  attributeKeys AttributeKey[]

  @@map("categories")
}

model AttributeKey {
  id                String             @id @default(uuid())
  categoryId        String             @map("category_id")
  name              String
  type              String             // "TEXT", "NUMBER", "SELECT"
  
  category          Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  productAttributes ProductAttribute[]

  @@map("attribute_keys")
}

model ProductAttribute {
  id             String       @id @default(uuid())
  productId      String       @map("product_id")
  attributeKeyId String       @map("attribute_key_id")
  value          String

  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeKey   AttributeKey @relation(fields: [attributeKeyId], references: [id], onDelete: Cascade)

  @@unique([productId, attributeKeyId])
  @@map("product_attributes")
}

model Bid {
  id               String   @id @default(uuid())
  productId        String   @map("product_id")
  userId           String   @map("user_id")
  bidAmount        Decimal  @map("bid_amount") @db.Decimal(12, 2)
  bidTime          DateTime @default(now()) @map("bid_time")
  status           BidStatus? @default(SUCCESS)
  ipAddress        String?  @map("ip_address")
  userAgent        String?  @map("user_agent")
  isAutoBid        Boolean  @default(false) @map("is_auto_bid")
  maxAutoBidAmount Decimal? @map("max_auto_bid_amount") @db.Decimal(12, 2)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@map("bids")
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  amount    Decimal  @db.Decimal(12, 2)
  type      TransactionType
  status    TransactionStatus @default(COMPLETED)
  createdAt DateTime @default(now()) @map("created_at")
  productId String?  @map("product_id")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([productId])
  @@map("transactions")
}

// Yêu cầu nạp/rút tiền — thay thế hệ thống liên kết ngân hàng
model WalletRequest {
  id            String             @id @default(uuid())
  userId        String             @map("user_id")
  type          WalletRequestType
  amount        Decimal            @db.Decimal(12, 2)
  status        WalletRequestStatus @default(PENDING)
  bankName      String?            @map("bank_name")      // Ngân hàng của user (cho WITHDRAW)
  bankAccount   String?            @map("bank_account")   // Số TK user (cho WITHDRAW)
  bankOwner     String?            @map("bank_owner")     // Tên chủ TK user (cho WITHDRAW)
  transferNote  String?            @map("transfer_note")  // Nội dung chuyển khoản reference
  adminNote     String?            @map("admin_note")     // Ghi chú của admin khi xử lý
  createdAt     DateTime           @default(now()) @map("created_at")
  resolvedAt    DateTime?          @map("resolved_at")
  resolvedById  String?            @map("resolved_by_id")

  user          User               @relation("UserWalletRequests", fields: [userId], references: [id], onDelete: Cascade)
  resolvedBy    User?              @relation("AdminResolvedRequests", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([type])
  @@map("wallet_requests")
}

model DisputeTicket {
  id               String           @id @default(uuid())
  productId        String           @unique @map("product_id")
  openedById       String           @map("opened_by_id")
  reason           String
  description      String
  unboxingVideoUrl String?          @map("unboxing_video_url")
  status           DisputeStatus    @default(PENDING)
  createdAt        DateTime         @default(now()) @map("created_at")

  product          Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  openedBy         User             @relation("UserDisputeTickets", fields: [openedById], references: [id], onDelete: Cascade)
  messages         DisputeMessage[]

  @@index([openedById])
  @@map("dispute_tickets")
}

model DisputeMessage {
  id        String        @id @default(uuid())
  ticketId  String        @map("ticket_id")
  senderId  String        @map("sender_id")
  message   String
  createdAt DateTime      @default(now()) @map("created_at")

  ticket    DisputeTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender    User          @relation("UserDisputeMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([senderId])
  @@map("dispute_messages")
}

model Review {
  id           String   @id @default(uuid())
  reviewerId   String   @map("reviewer_id")
  targetUserId String   @map("target_user_id")
  productId    String   @unique @map("product_id")
  rating       Int
  comment      String?
  createdAt    DateTime @default(now()) @map("created_at")

  reviewer   User    @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  targetUser User    @relation("ReviewsReceived", fields: [targetUserId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([reviewerId])
  @@index([targetUserId])
  @@map("reviews")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  type      NotificationType
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model Watchlist {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation("UserWatchlist", fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation("ProductWatchlist", fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@map("watchlist")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  target    String?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  details   String?
  createdAt DateTime @default(now()) @map("created_at")

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model SupportTicket {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  subject     String
  status      String           @default("OPEN") // "OPEN", "CLOSED"
  createdAt   DateTime         @default(now()) @map("created_at")

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    SupportMessage[]

  @@map("support_tickets")
}

model SupportMessage {
  id        String        @id @default(uuid())
  ticketId  String        @map("ticket_id")
  senderId  String        @map("sender_id")
  message   String
  sentAt    DateTime      @default(now()) @map("sent_at")

  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender    User          @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@map("support_messages")
}

enum KycStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum ProductStatus {
  ACTIVE
  PENDING_PAYMENT
  PAID
  SHIPPED
  COMPLETED
  UNSOLD
  DISPUTED
  ENDED
  DRAFT
  CANCELLED
}

enum ProductApprovalStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum BidStatus {
  SUCCESS
  OUTBID
  REFUNDED
  CANCELLED
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  HOLD_ESCROW
  RELEASE_ESCROW
  PAYMENT
  DISPUTE_PAY_BUYER_DEDUCT
  DISPUTE_PAY_SELLER_ADD
  REFUND
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum DisputeStatus {
  PENDING
  RESOLVED
}

enum NotificationType {
  OUTBID
  WON
  SYSTEM
  AUCTION_CANCELLED
  PRODUCT_APPROVED
  PRODUCT_REJECTED
  WALLET_REQUEST_APPROVED
  WALLET_REQUEST_REJECTED
}

enum WalletRequestType {
  DEPOSIT
  WITHDRAW
}

enum WalletRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model OrderMessage {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  senderId  String   @map("sender_id")
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  product   Product  @relation("ProductOrderMessages", fields: [productId], references: [id], onDelete: Cascade)
  sender    User     @relation("UserOrderMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([senderId])
  @@map("order_messages")
}

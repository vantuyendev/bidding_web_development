datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String        @id @default(uuid())
  email           String        @unique
  passwordHash    String        @map("password_hash")
  balance         Decimal       @default(10000000.00) @db.Decimal(12, 2)
  walletBalance   Decimal       @default(0) @db.Decimal(12, 2) @map("wallet_balance")
  frozenBalance   Decimal       @default(0) @db.Decimal(12, 2) @map("frozen_balance")
  reputationScore Float         @default(5.0) @map("reputation_score")
  createdAt       DateTime      @default(now()) @map("created_at")
  bids            Bid[]
  transactions    Transaction[]

  @@map("users")
}

model Product {
  id            String             @id @default(uuid())
  title         String
  description   String?
  imageUrl      String?            @map("image_url")
  startPrice    Decimal            @map("start_price") @db.Decimal(12, 2)
  currentPrice  Decimal            @map("current_price") @db.Decimal(12, 2)
  buyNowPrice   Decimal?           @map("buy_now_price") @db.Decimal(12, 2)
  reservePrice  Decimal?           @map("reserve_price") @db.Decimal(12, 2)
  stepPrice     Decimal            @default(10000) @map("step_price") @db.Decimal(12, 2)
  autoExtension Boolean            @default(true) @map("auto_extension")
  startTime     DateTime           @default(now()) @map("start_time")
  endTime       DateTime           @map("end_time")
  status        String             @default("active")
  categoryId    String             @map("category_id")
  
  category      Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  bids          Bid[]
  attributes    ProductAttribute[]

  @@map("products")
}

model Category {
  id            String         @id @default(uuid())
  name          String
  slug          String         @unique
  products      Product[]
  attributeKeys AttributeKey[]

  @@map("categories")
}

model AttributeKey {
  id                String             @id @default(uuid())
  categoryId        String             @map("category_id")
  name              String
  type              String             // "TEXT", "NUMBER", "SELECT"
  
  category          Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  productAttributes ProductAttribute[]

  @@map("attribute_keys")
}

model ProductAttribute {
  id             String       @id @default(uuid())
  productId      String       @map("product_id")
  attributeKeyId String       @map("attribute_key_id")
  value          String

  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeKey   AttributeKey @relation(fields: [attributeKeyId], references: [id], onDelete: Cascade)

  @@unique([productId, attributeKeyId])
  @@map("product_attributes")
}

model Bid {
  id               String   @id @default(uuid())
  productId        String   @map("product_id")
  userId           String   @map("user_id")
  bidAmount        Decimal  @map("bid_amount") @db.Decimal(12, 2)
  bidTime          DateTime @default(now()) @map("bid_time")
  status           String?  @default("success")
  ipAddress        String?  @map("ip_address")
  userAgent        String?  @map("user_agent")
  isAutoBid        Boolean  @default(false) @map("is_auto_bid")
  maxAutoBidAmount Decimal? @map("max_auto_bid_amount") @db.Decimal(12, 2)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bids")
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  amount    Decimal  @db.Decimal(12, 2)
  type      String
  status    String   @default("COMPLETED")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}
